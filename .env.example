# Deployment configuration - Annotation Tool
# ========================================

# PostgreSQL credentials (used by the db service and to build DATABASE_URL)
POSTGRES_USER=lace
POSTGRES_PASSWORD=lace
POSTGRES_DB=lacedb
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Database URL — built from the fields above for Docker Compose (host = service name "db")
DATABASE_URL=postgresql+psycopg2://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
# For local SQLite development:
# DATABASE_URL=sqlite:///./data/app.db

# Backend configuration
# NOTE: must be at least 32 characters
SECRET_KEY=change-me-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Security (optional overrides)
PASSWORD_MIN_LENGTH=10
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_LETTER=true
AUTH_RATE_LIMIT_REQUESTS=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=60

# Initial admin user (change for production)
FIRST_ADMIN_USERNAME=admin
FIRST_ADMIN_PASSWORD=change-me-strong-123

# CORS origins (explicit per environment)
CORS_ORIGINS=["http://localhost:3721"]

# Frontend configuration
API_URL=http://localhost:8000

# Import limits (optional overrides)
MAX_UPLOAD_MB=10
MAX_IMPORT_ROWS=50000

# ========================================
# Usage
# ========================================
# 1) Copy this file to .env
#    cp .env.example .env
#
# 2) For production, update SECRET_KEY, admin password, and POSTGRES_PASSWORD
#
# 3) Run with Docker Compose
#    docker compose up --build -d
