# Deployment configuration - Annotation Tool
# Copy to .env and update the values before running docker compose up --build -d

# PostgreSQL credentials
POSTGRES_USER=lace
POSTGRES_PASSWORD=change-me
POSTGRES_DB=lacedb

# Database URL (uses the credentials above; host "db" is the compose service name)
DATABASE_URL=postgresql+psycopg2://lace:change-me@db:5432/lacedb

# Backend
SECRET_KEY=change-me-min-32-chars
FIRST_ADMIN_USERNAME=admin
FIRST_ADMIN_PASSWORD=change-me-strong-123

# CORS — set to the public URL of the frontend
CORS_ORIGINS=["http://localhost:3721"]

# Token expiry
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Password policy
PASSWORD_MIN_LENGTH=10
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_LETTER=true

# Auth rate limiting
AUTH_RATE_LIMIT_REQUESTS=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
